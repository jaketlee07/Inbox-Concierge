# Inbox Concierge — environment variables
#
# Copy this file to `.env.local` and fill in real values. `.env.local` is
# gitignored. The Zod schema in lib/env.schema.ts validates these on boot;
# the app will refuse to start if any required value is missing or malformed.
#
# For Vercel deploys, set these in the project's Environment Variables tab
# (Settings → Environment Variables) for Production, Preview, AND Development.

# --- Supabase ---
# Project Settings → API. The anon key is safe to ship to the browser; the
# service-role key is server-only and bypasses RLS — never expose it.
NEXT_PUBLIC_SUPABASE_URL=https://<your-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Google OAuth ---
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client.
# Used server-side for the refresh-token grant in lib/gmail/tokenManager.ts.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Anthropic ---
# console.anthropic.com → Settings → API Keys. Must literally start with `sk-ant-`.
ANTHROPIC_API_KEY=sk-ant-

# --- Upstash Redis (rate limiting) ---
# console.upstash.com → create a Redis DB → REST tab.
UPSTASH_REDIS_REST_URL=https://<your-host>.upstash.io
UPSTASH_REDIS_REST_TOKEN=

# --- Database encryption key ---
# Used to encrypt OAuth refresh tokens at rest (AES-256-GCM in lib/crypto.ts).
# Must be ≥ 32 characters. Generate with: openssl rand -base64 32
# IMPORTANT: pick once and never change it — rotating orphans every encrypted
# refresh token in oauth_tokens, forcing every user to re-sign-in.
DB_ENCRYPTION_KEY=

# --- Sentry (optional) ---
# Leave blank to disable. If set, both must be valid URLs.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
